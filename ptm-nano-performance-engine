// API MasterProMax - Version Performance Vercel
// مسار الملف فـ GitHub: /api/MasterProMax.js

module.exports = async (req, res) => {
    // 1. استخراج المعطيات من الطلب (Query Parameters)
    const { 
        production, tonnesVendues, tonnesRetour, 
        prixVente, prixRecup, 
        coeffCimentPercent, coeffVariablePercent, coeffFixesPercent 
    } = req.query;

    // 2. التحويل للأرقام (مع حماية ضد الفراغ)
    const data = {
        production: parseFloat(production) || 0,
        tonnesVendues: parseFloat(tonnesVendues) || 0,
        tonnesRetour: parseFloat(tonnesRetour) || 0,
        prixVente: parseFloat(prixVente) || 0,
        prixRecup: parseFloat(prixRecup) || 0,
        coeffCimentPercent: parseFloat(coeffCimentPercent) || 0,
        coeffVariablePercent: parseFloat(coeffVariablePercent) || 0,
        coeffFixesPercent: parseFloat(coeffFixesPercent) || 0
    };

    // 3. الحسابات
    const coutCiment = data.production * (data.coeffCimentPercent / 100);
    const coutVariable = data.production * (data.coeffVariablePercent / 100);
    const coutFixes = data.production * (data.coeffFixesPercent / 100);
    const totalCost = coutCiment + coutVariable + coutFixes;
    
    const revenue = (data.tonnesVendues * data.prixVente) + (data.tonnesRetour * data.prixRecup);
    const margeNet = revenue - totalCost;
    
    let totalSorti = data.tonnesVendues + data.tonnesRetour;
    let tauxPerte = totalSorti > 0 ? (data.tonnesRetour / totalSorti) * 100 : 0;
    
    let statut = (tauxPerte > 15) ? "ALERT: Taux de perte élevé! Vérifier dosage." : "STATUS: Performance optimale.";

    // 4. إرجاع النتيجة (JSON Response)
    res.status(200).json({
        margeNet: margeNet.toFixed(2) + " DH",
        tauxPerte: tauxPerte.toFixed(2) + "%",
        statut: statut,
        details: {
            totalCost: totalCost.toFixed(2),
            revenue: revenue.toFixed(2)
        }
    });
};
